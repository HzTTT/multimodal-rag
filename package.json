{
  "name": "@hzttt/multimodal-rag",
  "version": "0.5.3",
  "description": "OpenClaw plugin for multimodal RAG - semantic indexing and time-aware search for images and audio using local AI models",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/hzttt/multimodal-rag.git"
  },
  "scripts": {
    "sync:version": "node scripts/sync-version.mjs",
    "build": "npm run sync:version && tsc",
    "test": "node test/test-embedding.js",
    "prepack": "npm run sync:version",
    "version": "npm run sync:version && git add openclaw.plugin.json"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "rag",
    "multimodal",
    "vision",
    "embedding",
    "lancedb",
    "ollama",
    "whisper"
  ],
  "author": "hzttt",
  "license": "MIT",
  "files": [
    "index.ts",
    "plugin-runtime.ts",
    "src/",
    "openclaw.plugin.json",
    "README.md"
  ],
  "dependencies": {
    "@lancedb/lancedb": "^0.14.0",
    "@sinclair/typebox": "^0.33.0",
    "apache-arrow": "^18.1.0",
    "chokidar": "^4.0.0",
    "officeparser": "^5.0.0",
    "pdfjs-dist": "^4.8.69"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@hzttt/multimodal-rag"
    }
  },
  "peerDependencies": {
    "openclaw": "*"
  },
  "devDependencies": {
    "openclaw": "^2026.3.23",
    "typescript": "^5.9.3"
  }
}
