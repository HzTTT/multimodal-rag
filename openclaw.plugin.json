{
  "id": "multimodal-rag",
  "name": "Multimodal RAG",
  "description": "多模态 RAG 插件，使用本地 AI 模型对图像、音频和文档进行语义索引与时间感知搜索；源文件删除时自动移除索引（不会删除原文件）",
  "version": "0.5.3",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "watchPaths": {
        "type": "array",
        "items": { "type": "string" },
        "default": [],
        "description": "监听的文件夹路径列表（支持 ~ 展开）"
      },
      "fileTypes": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "image": {
            "type": "array",
            "items": { "type": "string" },
            "default": [".jpg", ".jpeg", ".png", ".webp", ".gif", ".heic"]
          },
          "audio": {
            "type": "array",
            "items": { "type": "string" },
            "default": [".wav", ".mp3", ".m4a", ".ogg", ".flac", ".aac"]
          },
          "document": {
            "type": "array",
            "items": { "type": "string" },
            "default": [".pdf", ".docx", ".xlsx", ".pptx", ".txt", ".md", ".markdown", ".html", ".htm"]
          }
        },
        "default": {}
      },
      "ollama": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "baseUrl": {
            "type": "string",
            "default": "http://127.0.0.1:11434"
          },
          "apiKey": {
            "type": "string",
            "description": "Ollama API Key（远程 Ollama 或 API 网关时需要，请求中附带 Authorization: Bearer header）"
          },
          "visionModel": {
            "type": "string",
            "default": "qwen3-vl:2b",
            "description": "用于图像描述的视觉模型"
          },
          "embedModel": {
            "type": "string",
            "default": "qwen3-embedding:latest",
            "description": "用于生成嵌入向量的模型"
          },
          "ocrModel": {
            "type": "string",
            "description": "用于文档/图片 OCR 的 VLM 模型，留空则复用 visionModel（可填 gemma3:27b / qwen2.5-vl:32b 等）"
          }
        },
        "default": {}
      },
      "embedding": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "provider": {
            "type": "string",
            "enum": ["ollama", "openai"],
            "default": "ollama"
          },
          "openaiApiKey": {
            "type": "string",
            "description": "OpenAI API Key（仅当 provider=openai 时需要）"
          },
          "openaiModel": {
            "type": "string",
            "default": "text-embedding-3-small"
          }
        },
        "default": {}
      },
      "whisper": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "provider": {
            "type": "string",
            "enum": ["local", "zhipu"],
            "default": "local"
          },
          "zhipuApiKey": {
            "type": "string",
            "description": "智谱 API Key（仅当 provider=zhipu 时需要）"
          },
          "zhipuApiBaseUrl": {
            "type": "string",
            "description": "智谱 API 地址（可选）"
          },
          "zhipuModel": {
            "type": "string",
            "default": "glm-asr-2512"
          },
          "language": {
            "type": "string",
            "default": "zh",
            "description": "本地 Whisper 使用的语言提示"
          }
        },
        "default": {}
      },
      "document": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "chunkSize": {
            "type": "number",
            "default": 800,
            "description": "文档切片目标字符数"
          },
          "chunkOverlap": {
            "type": "number",
            "default": 120,
            "description": "相邻 chunk 的重叠字符数（必须 < chunkSize）"
          },
          "ocrTriggerChars": {
            "type": "number",
            "default": 30,
            "description": "PDF 一页 pdfjs 提取字数低于该阈值时，自动触发 OCR"
          },
          "ocrEnabled": {
            "type": "boolean",
            "default": true,
            "description": "是否启用 OCR 回落（false 时扫描件 PDF 会被跳过成空白页）"
          }
        },
        "default": {}
      },
      "dbPath": {
        "type": "string",
        "default": "~/.openclaw/multimodal-rag.lance",
        "description": "LanceDB 数据库路径"
      },
      "watchDebounceMs": {
        "type": "number",
        "default": 1000,
        "description": "文件监听去抖延迟（毫秒）"
      },
      "indexExistingOnStart": {
        "type": "boolean",
        "default": true,
        "description": "启动时是否索引现有文件"
      },
      "http": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": false,
            "description": "启用 HTTP 服务（/get_file_info + /search_file），随 gateway 生命周期自动启停"
          },
          "host": {
            "type": "string",
            "default": "127.0.0.1",
            "description": "HTTP 绑定地址；默认仅本机访问，如需跨机请显式改为 0.0.0.0 或具体 IP"
          },
          "port": {
            "type": "number",
            "default": 7749,
            "description": "HTTP 监听端口"
          },
          "searchLimit": {
            "type": "number",
            "default": 20,
            "description": "/search_file 返回条数上限"
          },
          "searchMinScore": {
            "type": "number",
            "default": 0.25,
            "description": "/search_file 最低匹配分数 (0-1)"
          },
          "enableIndexOnDemand": {
            "type": "boolean",
            "default": false,
            "description": "/get_file_info 命中未索引文件时是否同步触发 indexPath（会拖慢响应）"
          }
        },
        "default": {}
      },
      "notifications": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": false,
            "description": "启用索引通知（默认唤醒 agent 回复）"
          },
          "agentId": {
            "type": "string",
            "description": "用于触发通知回复的 agent ID（默认 main）"
          },
          "quietWindowMs": {
            "type": "number",
            "default": 30000,
            "description": "静默窗口：最后一个文件处理完后等待多久再发送总结（毫秒）"
          },
          "batchTimeoutMs": {
            "type": "number",
            "default": 600000,
            "description": "批次最大超时：超过此时间强制发送总结（毫秒）"
          },
          "channel": {
            "type": "string",
            "default": "last",
            "description": "通知渠道（默认 last）"
          },
          "to": {
            "type": "string",
            "description": "通知目标（可选）"
          },
          "targets": {
            "type": "array",
            "description": "通知目标列表（用于 agent 的 reply-channel/reply-to）",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "channel": {
                  "type": "string",
                  "description": "消息渠道（如 feishu / qq / telegram）"
                },
                "to": {
                  "type": "string",
                  "description": "消息目标（chatId/groupId/uid）"
                },
                "accountId": {
                  "type": "string",
                  "description": "可选账号 ID（对应 --account）"
                }
              }
            }
          }
        },
        "default": {}
      }
    }
  },
  "uiHints": {
    "watchPaths": {
      "label": "监听路径",
      "placeholder": "~/mic-recordings"
    },
    "ollama.visionModel": {
      "label": "视觉模型",
      "placeholder": "qwen3-vl:2b"
    },
    "ollama.apiKey": {
      "label": "Ollama API Key",
      "sensitive": true,
      "help": "远程 Ollama 或经 API 网关访问时填写，会附带在每次请求的 Authorization header 中"
    },
    "ollama.embedModel": {
      "label": "嵌入模型",
      "placeholder": "qwen3-embedding:latest"
    },
    "ollama.ocrModel": {
      "label": "OCR 模型",
      "advanced": true,
      "placeholder": "留空复用 visionModel；可填 gemma3:27b / qwen2.5-vl:32b"
    },
    "embedding.openaiApiKey": {
      "label": "OpenAI API Key",
      "sensitive": true
    },
    "document.chunkSize": {
      "label": "文档切片大小",
      "advanced": true
    },
    "document.chunkOverlap": {
      "label": "文档切片重叠",
      "advanced": true
    },
    "document.ocrTriggerChars": {
      "label": "OCR 触发阈值",
      "advanced": true,
      "help": "PDF 一页字符数低于该阈值即判定为扫描页走 OCR"
    },
    "document.ocrEnabled": {
      "label": "启用 OCR",
      "help": "关闭后扫描件 PDF 会被跳过"
    },
    "dbPath": {
      "label": "数据库路径",
      "advanced": true
    },
    "watchDebounceMs": {
      "label": "去抖延迟（毫秒）",
      "advanced": true
    },
    "notifications.enabled": {
      "label": "启用通知",
      "help": "索引开始/完成时触发通知"
    },
    "notifications.agentId": {
      "label": "通知 Agent ID",
      "advanced": true,
      "help": "用于触发通知回复的 agent（默认 main）"
    },
    "notifications.quietWindowMs": {
      "label": "静默窗口（毫秒）",
      "advanced": true,
      "help": "最后一个文件处理完后等待多久再发送总结"
    },
    "notifications.batchTimeoutMs": {
      "label": "批次超时（毫秒）",
      "advanced": true,
      "help": "超过此时间强制发送总结，防止大批量索引时等太久"
    },
    "notifications.channel": {
      "label": "通知渠道",
      "advanced": true,
      "help": "通知渠道（不填则自动取最近活跃会话）"
    },
    "notifications.to": {
      "label": "通知目标",
      "advanced": true,
      "help": "通知目标（不填则自动取最近活跃会话）"
    },
    "notifications.targets": {
      "label": "通知目标列表",
      "advanced": true,
      "help": "用于通知回复的渠道/目标列表"
    }
  }
}
