{
  "id": "multimodal-rag",
  "name": "Multimodal RAG",
  "description": "多模态 RAG 插件，使用本地 AI 模型对图像和音频进行语义索引与时间感知搜索；源文件删除时自动移除索引（不会删除原文件）",
  "version": "0.4.5",
  "kind": "rag",
  "configSchema": {
    "type": "object",
    "properties": {
      "watchPaths": {
        "type": "array",
        "items": { "type": "string" },
        "default": [],
        "description": "监听的文件夹路径列表（支持 ~ 展开）"
      },
      "fileTypes": {
        "type": "object",
        "properties": {
          "image": {
            "type": "array",
            "items": { "type": "string" },
            "default": [".jpg", ".jpeg", ".png", ".webp", ".gif", ".heic"]
          },
          "audio": {
            "type": "array",
            "items": { "type": "string" },
            "default": [".wav", ".mp3", ".m4a", ".ogg", ".flac", ".aac"]
          }
        },
        "default": {}
      },
      "ollama": {
        "type": "object",
        "properties": {
          "baseUrl": {
            "type": "string",
            "default": "http://127.0.0.1:11434"
          },
          "apiKey": {
            "type": "string",
            "description": "Ollama API Key（远程 Ollama 或 API 网关时需要，请求中附带 Authorization: Bearer header）"
          },
          "visionModel": {
            "type": "string",
            "default": "qwen3-vl:2b",
            "description": "用于图像描述的视觉模型"
          },
          "embedModel": {
            "type": "string",
            "default": "qwen3-embedding:latest",
            "description": "用于生成嵌入向量的模型"
          }
        },
        "default": {}
      },
      "embedding": {
        "type": "object",
        "properties": {
          "provider": {
            "type": "string",
            "enum": ["ollama", "openai"],
            "default": "ollama"
          },
          "openaiApiKey": {
            "type": "string",
            "description": "OpenAI API Key（仅当 provider=openai 时需要）"
          },
          "openaiModel": {
            "type": "string",
            "default": "text-embedding-3-small"
          }
        },
        "default": {}
      },
      "dbPath": {
        "type": "string",
        "default": "~/.openclaw/multimodal-rag.lance",
        "description": "LanceDB 数据库路径"
      },
      "watchDebounceMs": {
        "type": "number",
        "default": 1000,
        "description": "文件监听去抖延迟（毫秒）"
      },
      "indexExistingOnStart": {
        "type": "boolean",
        "default": true,
        "description": "启动时是否索引现有文件"
      },
      "notifications": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": false,
            "description": "启用索引通知（默认唤醒 agent 回复）"
          },
          "agentId": {
            "type": "string",
            "description": "用于触发通知回复的 agent ID（默认 main）"
          },
          "quietWindowMs": {
            "type": "number",
            "default": 30000,
            "description": "静默窗口：最后一个文件处理完后等待多久再发送总结（毫秒）"
          },
          "batchTimeoutMs": {
            "type": "number",
            "default": 600000,
            "description": "批次最大超时：超过此时间强制发送总结（毫秒）"
          },
          "channel": {
            "type": "string",
            "default": "last",
            "description": "通知渠道（默认 last）"
          },
          "to": {
            "type": "string",
            "description": "通知目标（可选）"
          },
          "targets": {
            "type": "array",
            "description": "通知目标列表（用于 agent 的 reply-channel/reply-to）",
            "items": {
              "type": "object",
              "properties": {
                "channel": {
                  "type": "string",
                  "description": "消息渠道（如 feishu / qq / telegram）"
                },
                "to": {
                  "type": "string",
                  "description": "消息目标（chatId/groupId/uid）"
                },
                "accountId": {
                  "type": "string",
                  "description": "可选账号 ID（对应 --account）"
                }
              }
            }
          }
        },
        "default": {}
      }
    }
  },
  "uiHints": {
    "watchPaths": {
      "label": "监听路径",
      "placeholder": "~/mic-recordings"
    },
    "ollama.visionModel": {
      "label": "视觉模型",
      "placeholder": "qwen3-vl:2b"
    },
    "ollama.apiKey": {
      "label": "Ollama API Key",
      "sensitive": true,
      "help": "远程 Ollama 或经 API 网关访问时填写，会附带在每次请求的 Authorization header 中"
    },
    "ollama.embedModel": {
      "label": "嵌入模型",
      "placeholder": "qwen3-embedding:latest"
    },
    "embedding.openaiApiKey": {
      "label": "OpenAI API Key",
      "sensitive": true
    },
    "dbPath": {
      "label": "数据库路径",
      "advanced": true
    },
    "watchDebounceMs": {
      "label": "去抖延迟（毫秒）",
      "advanced": true
    },
    "notifications.enabled": {
      "label": "启用通知",
      "help": "索引开始/完成时触发通知"
    },
    "notifications.agentId": {
      "label": "通知 Agent ID",
      "advanced": true,
      "help": "用于触发通知回复的 agent（默认 main）"
    },
    "notifications.quietWindowMs": {
      "label": "静默窗口（毫秒）",
      "advanced": true,
      "help": "最后一个文件处理完后等待多久再发送总结"
    },
    "notifications.batchTimeoutMs": {
      "label": "批次超时（毫秒）",
      "advanced": true,
      "help": "超过此时间强制发送总结，防止大批量索引时等太久"
    },
    "notifications.channel": {
      "label": "通知渠道",
      "advanced": true,
      "help": "通知渠道（不填则自动取最近活跃会话）"
    },
    "notifications.to": {
      "label": "通知目标",
      "advanced": true,
      "help": "通知目标（不填则自动取最近活跃会话）"
    },
    "notifications.targets": {
      "label": "通知目标列表",
      "advanced": true,
      "help": "用于通知回复的渠道/目标列表"
    }
  }
}
